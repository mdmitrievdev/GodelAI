# ============================================================
# PR Review Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
POSTGRES_DB=pr_review_assistant
POSTGRES_USER=pguser
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# .NET reads this as ConnectionStrings:DefaultConnection
# Uses Docker service name "db" as the host.
ConnectionStrings__DefaultConnection=Host=db;Database=pr_review_assistant;Username=pguser;Password=changeme

# ------------------------------------------------------------
# Backend API
# ------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ------------------------------------------------------------
# AI Analysis
# ------------------------------------------------------------
# Set to "true" to use the built-in mock service (no API key needed).
# Set to "false" to use OpenAI (requires OPENAI_API_KEY).
USE_MOCK_AI=true

# Required only when USE_MOCK_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------
# GitHub API (optional — for fetching PR diffs by URL)
# ------------------------------------------------------------
GITHUB_TOKEN=

# ------------------------------------------------------------
# Frontend (Vite — build-time variables)
# ------------------------------------------------------------
# Docker: leave empty — nginx proxies /api/ to backend, so relative URLs work.
# Local dev: set to http://localhost:8080
VITE_API_BASE_URL=
